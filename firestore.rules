rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection: doc ID = the admin's Firebase Auth UID.
    // Add yourself here manually in the Firebase console (Firestore > admins > {your-uid} > { role: "admin" })
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // manage this manually from the Firebase console
    }

    // A shop's own profile document — the shop itself or the admin can read/write it
    match /shops/{shopId} {
      allow read, write: if request.auth != null && request.auth.uid == shopId;
      allow read: if isAdmin();

      // Inventory and restock list are nested under the shop
      match /inventory/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == shopId;
        allow read: if isAdmin();
      }
      match /restockList/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == shopId;
        allow read: if isAdmin();
      }
    }

    // Orders: a shop can create its own orders and read them back.
    // The admin can read and update (status) across every shop's orders.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.shopId;
      allow read: if request.auth != null && request.auth.uid == resource.data.shopId;
      allow read, update: if isAdmin();
    }
  }
}
